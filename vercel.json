{
    "version": 2,
    "builds": [
        {
            "src": "Attendance/**/*",
            "use": "@vercel/static"
        },
        {
            "src": "backend/main.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/backend/main.js"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "/backend/main.js"
        },
        {
            "src": "/(.*)",
            "dest": "/Attendance/$1"
        }
    ]
}